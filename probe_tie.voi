package main

func take(own n int) int { return n }

func main() {
    let a = 5
    take(a)
    // Two checks fire at the SAME position (a, col 16): the lattice says
    // int -> i8 is lossy, and the move check says `a` was moved. Go's
    // sort.SliceStable keeps checkLattice's diagnostic first because
    // checkLattice runs before checkMoves.
    let b i8 = a
    say b
}
