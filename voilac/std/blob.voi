// Package std — the Voilà-source standard library, carried
// inside the compiler.
//
// GENERATED by tools/build.voi. Do not edit: change std/ and
// rebuild. `use "std/net"` grafts these packages into a user
// program (see voilac/load/load.voi). The payload is base64
// because Voilà source is not a legal Voilà string literal.
package std

// Packages lists the std packages that have Voilà source.
func Packages() []str {
    return [
        "net",
    ]
}

// Files lists a package's source files, in load order.
func Files(pkg str) []str {
    if pkg == "net" {
        return [
            "net.voi",
        ]
    }
    return []
}

// Source returns one file's text.
func Source(pkg str, file str) str {
    if pkg == "net" and file == "net.voi" { return unb64("") }
    return ""
}
