// Package rt — libvoila's source, carried inside the compiler.
//
// GENERATED by tools/build.voi. Do not edit: change runtime/src/
// and rebuild.
//
// `voila build` writes these files next to the C it emits and
// compiles the whole set with the system cc, so a produced binary
// depends on nothing but libc. The payload is base64 because C
// source is not a legal Voilà string literal.
package rt

use "std/os"
use "std/str"

// Names lists the runtime's files, headers first.
func Names() []str {
    return [
        "voila.h",
        "voila_int.h",
        "voila_std.h",
        "call.c",
        "coll.c",
        "dec.c",
        "err.c",
        "fmt.c",
        "ops.c",
        "std.c",
        "str.c",
        "task.c",
        "types.c",
        "value.c",
    ]
}

// Data returns each file's contents, in the order Names gives.
func Data() []str {
    var out = []
    out.append(unb64(""))
    out.append(unb64(""))
    out.append(unb64(""))
    out.append(unb64(""))
    out.append(unb64(""))
    out.append(unb64(""))
    out.append(unb64(""))
    out.append(unb64(""))
    out.append(unb64(""))
    out.append(unb64(""))
    out.append(unb64(""))
    out.append(unb64(""))
    out.append(unb64(""))
    out.append(unb64(""))
    return out
}

// WriteTo writes libvoila's source into a directory and returns
// the paths of the .c files, which are what `cc` must be handed.
func WriteTo(dir str) []str throws IOError {
    var cfiles = []
    let names = Names()
    let data = Data()
    each i, n in names {
        let p = dir || "/" || n
        try os.write(p, data[i])
        if str.ends_with(n, ".c") { cfiles.append(p) }
    }
    return cfiles
}
